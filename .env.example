# Required (min 16 chars). Used to sign session cookies.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only; never expose to the browser. Required for API routes.
SUPABASE_SERVICE_ROLE_KEY=

# Required for /admin login (min 16 chars). Can differ from SESSION_SECRET.
ADMIN_SESSION_SECRET=

# Optional: Postgres URI for `npm run db:apply-schema` (Dashboard → Database → Connection string)
# DATABASE_URL=
