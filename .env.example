# --- Required on Vercel (Production + Preview): copy this file to .env locally ---
#
# Secrets (min 16 characters each). Generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET / ADMIN_SESSION_SECRET are optional on the server if SUPABASE_SERVICE_ROLE_KEY is set (keys are derived).
SESSION_SECRET=
ADMIN_SESSION_SECRET=
# Required for /api/verification/* (encrypting doc URLs). App boots without it; those routes fail until set.
VERIFICATION_DOC_SECRET=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: canonical public URL (no trailing slash). Improves Supabase email redirect links on Vercel.
# Also add this URL + /auth/callback to Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
# (e.g. https://your-domain.vercel.app/auth/callback and http://127.0.0.1:3000/auth/callback for local dev).
NEXT_PUBLIC_SITE_URL=

# Server-only; never expose to the browser. Required for API routes.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: required only for PATCH /api/app-settings (403 if unset when patching).
# APP_SETTINGS_ADMIN_SECRET=

# Optional: Postgres URI for `npm run db:apply-schema` (Dashboard → Database → Connection string)
# DATABASE_URL=
